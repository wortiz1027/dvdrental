{
	"name": "🍃 Ubuntu :: Spring Boot {DvD Rental} 🍃",
	"image": "mcr.microsoft.com/devcontainers/base:resolute",
  "hostRequirements": {
    "cpus": 2,
		"memory": "6gb",
		"storage": "5gb",
    "gpu": false
	},
	"features": {
		"ghcr.io/devcontainers/features/common-utils:2": {
			"installZsh": true,
			"configureZshAsDefaultShell": true,
			"installOhMyZsh": true,
			"installOhMyZshConfig": true,
			"upgradePackages": true,
			"configureGpgWithGpgAgent": true
		},
		"ghcr.io/devcontainers-extra/features/zsh-plugins:0": {
			"plugins": "zsh-autosuggestions zsh-syntax-highlighting",
			"omzPlugins": "https://github.com/zsh-users/zsh-autosuggestions.git https://github.com/zsh-users/zsh-syntax-highlighting.git"
		}
	},
	"customizations": {
		"projectMetadata": {
			"author": "@DevSoft Team",
			"repository": "git@github.com:wortiz1027/dvdrental.git",
			"version": "1.0.0",
			"license": "MIT",
			"environment": "Development"
		},
		"vscode": {
			"extensions": [
				"anweber.vscode-httpyac",
				"esbenp.prettier-vscode",
				"EditorConfig.EditorConfig",
				"GraphQL.vscode-graphql",
				"redhat.vscode-yaml",
				"vscjava.vscode-java-pack",
				"vmware.vscode-boot-dev-pack",
				"GraphQL.vscode-graphql-syntax",
				"tamasfe.even-better-toml",
				"GitHub.github-vscode-theme",
				"zhuangtongfa.material-theme",
				"Semgrep.semgrep"
			],
			"settings": {
				"git.blame.editorDecoration.enabled": true,
				"git.blame.statusBarItem.enabled": true,
				"scm.experimental.showHistoryGraph": true,
				"editor.renderLineHighlight": "none",
				"editor.cursorSmoothCaretAnimation": "off",
				"workbench.colorCustomizations": {
					"git.blame.editorDecorationForeground": "#c7c7c788"
				},
				"editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.organizeImports": "explicit"
        },
				"dev.containers.forwardWayland": false,
				"terminal.integrated.defaultProfile.linux": "zsh",
				"git.autocrlf": "input",
				"editor.insertSpaces": true,
				"editor.tabSize": 4,
				"editor.renderIndentGuides": true,
				"java.compile.nullAnalysis.mode": "automatic",
				"java.jdt.ls.java.home": "/home/vscode/.local/share/mise/installs/java/latest",
				"java.import.gradle.home": "/home/vscode/.local/share/mise/installs/gradle/latest",
				"java.import.gradle.java.home": "/home/vscode/.local/share/mise/installs/java/latest",
				"sonarlint.ls.javaHome": "/home/vscode/.local/share/mise/installs/java/latest",
				"java.configuration.runtimes": [
					{
						"name": "JavaSE-25",
						"path": "/home/vscode/.local/share/mise/installs/java/latest",
						"default": true
					}
				]
			}
		}
	},
	"forwardPorts": [
		8080,
		3000
	],
	"portsAttributes": {
		"8080": {
			"label": "Servidor Web Java Backend",
			"onAutoForward": "notify"
		},
		"3000": {
			"label": "Servidor Web Docsify",
			"onAutoForward": "notify"
		}
	},
	"mounts": [
		"source=${localEnv:HOME}/.local/share/gopass,target=${containerWorkspaceFolder}/../.local/share/gopass,type=bind,consistency=cached",
		"source=${localEnv:HOME}/.config/gopass,target=/home/vscode/.config/gopass,type=bind,consistency=cached",
		"source=${localEnv:HOME}/.dotfiles/git/.gitconfig,target=/home/vscode/.gitconfig,type=bind,consistency=cached",
		"source=${localEnv:HOME}/.dotfiles/git/commit.template,target=/home/vscode/.config/git/commit.template,type=bind,consistency=cached",
		"source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh,type=bind,readonly,consistency=cached"
	],
	"runArgs": [
		"--security-opt",
		"label=disable",
    "--network=ntw_servers"
	],
	"remoteEnv": {
		"JAVA_HOME": "/home/vscode/.local/share/mise/installs/java/latest",
		"MISE_TRUSTED_CONFIG_PATHS": "/workspace",
		"GOPASS_HOMEDIR": "${containerWorkspaceFolder}/../",
		"GOPASS_STORE_DIR": "${containerWorkspaceFolder}/../.local/share/gopass/stores/root"
	},
	"workspaceFolder": "/workspace",
	"workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
	"onCreateCommand": "sudo chown -R vscode:vscode /workspace",
	"updateContentCommand": "chmod +x .devcontainer/dev/scripts/boostrap.sh && .devcontainer/dev/scripts/boostrap.sh",
	"containerUser": "vscode",
	"remoteUser": "vscode"
}
