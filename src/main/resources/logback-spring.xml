<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- 1. 🚀 SOLUCIÓN: Registrar las clases de conversión de Spring Boot para colores y excepciones -->
    <conversionRule conversionWord="clr" class="org.springframework.boot.logging.logback.ColorConverter" />
    <conversionRule conversionWord="wex" class="org.springframework.boot.logging.logback.WhitespaceThrowableProxyConverter" />
    <conversionRule conversionWord="wEx" class="org.springframework.boot.logging.logback.ExtendedWhitespaceThrowableProxyConverter" />

    <!-- 2. Definición del patrón de diseño de logs con soporte de colores ANSI (Ya reconocidos) -->
    <property name="CONSOLE_LOG_PATTERN"
              value="%clr(%d{yyyy-MM-dd HH:mm:ss.SSS}){faint} %clr(${LOG_LEVEL_PATTERN:-%5p}) %clr(${PID:- }){magenta} %clr(---){faint} %clr([%15.15t]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %m%n${LOG_EXCEPTION_CONVERSION_WORD:-%wEx}"/>

    <!-- 3. Appender de Consola Estándar (Síncrono) -->
    <appender name="SYNC_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            <charset>utf8</charset>
        </encoder>
    </appender>

    <!-- 4. Appender Asíncrono para proteger el rendimiento de tus Virtual Threads -->
    <appender name="ASYNC_CONSOLE" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="SYNC_CONSOLE" />
        <queueSize>50000</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <neverBlock>true</neverBlock>
    </appender>

    <!-- 5. Ajustes finos de niveles bajo carga extrema -->
    <logger name="co.com.devsoft.dvdrental" level="DEBUG" />
    <logger name="org.springframework" level="WARN" />
    <logger name="org.hibernate" level="WARN" />
    <logger name="com.zaxxer.hikari" level="WARN" />

    <!-- 6. Activación del flujo principal -->
    <root level="DEBUG">
        <appender-ref ref="ASYNC_CONSOLE" />
    </root>

</configuration>
